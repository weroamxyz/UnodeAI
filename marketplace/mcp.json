[
  {
    "id": "filesystem",
    "name": "Filesystem",
    "summary": "Secure file operations within an allowed root directory — read, write, list, and search.",
    "transport": "stdio",
    "command": "npx",
    "args": ["-y", "@modelcontextprotocol/server-filesystem", "${WORKDIR}"],
    "requiresApproval": true,
    "source": "https://github.com/modelcontextprotocol/servers/tree/main/src/filesystem"
  },
  {
    "id": "git",
    "name": "Git",
    "summary": "Read and query local Git repositories — log, diff, status, blame, and branch operations.",
    "transport": "stdio",
    "command": "uvx",
    "args": ["mcp-server-git", "--repository", "${WORKDIR}"],
    "requiresApproval": true,
    "prerequisite": "uv",
    "source": "https://github.com/modelcontextprotocol/servers/tree/main/src/git"
  },
  {
    "id": "github",
    "name": "GitHub",
    "summary": "Interact with GitHub — issues, PRs, repos, and code search via the GitHub API.",
    "transport": "stdio",
    "command": "npx",
    "args": ["-y", "@modelcontextprotocol/server-github"],
    "env": {
      "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
    },
    "requiresApproval": true,
    "source": "https://github.com/modelcontextprotocol/servers-archived/tree/main/src/github"
  },
  {
    "id": "fetch",
    "name": "Fetch",
    "summary": "Fetch and convert web content to markdown for LLM consumption — URLs only, no scripting.",
    "transport": "stdio",
    "command": "uvx",
    "args": ["mcp-server-fetch"],
    "requiresApproval": true,
    "prerequisite": "uv",
    "source": "https://github.com/modelcontextprotocol/servers/tree/main/src/fetch"
  },
  {
    "id": "memory",
    "name": "Memory",
    "summary": "Persistent knowledge graph for cross-session memory — entities, relations, and observations.",
    "transport": "stdio",
    "command": "npx",
    "args": ["-y", "@modelcontextprotocol/server-memory"],
    "requiresApproval": false,
    "source": "https://github.com/modelcontextprotocol/servers/tree/main/src/memory"
  },
  {
    "id": "hermes-bridge",
    "name": "Hermes Bridge",
    "summary": "Connect a local or remote Hermes-compatible MCP bridge for persistent memory, skills, and long-running agent tools without bundling the Hermes runtime.",
    "icon": "H",
    "transport": "streamable-http",
    "urlPrompt": {
      "title": "Hermes Bridge MCP URL",
      "prompt": "Enter the streamable HTTP MCP endpoint exposed by your Hermes bridge.",
      "placeHolder": "http://127.0.0.1:8765/mcp"
    },
    "requiresApproval": true
  },
  {
    "id": "sqlite",
    "name": "SQLite",
    "summary": "Query and mutate local SQLite databases with full SQL — schema inspection, SELECT, DML.",
    "transport": "stdio",
    "command": "uvx",
    "args": ["mcp-server-sqlite", "--db-path", "${WORKDIR}/roam.sqlite"],
    "requiresApproval": true,
    "prerequisite": "uv",
    "source": "https://github.com/modelcontextprotocol/servers-archived/tree/main/src/sqlite"
  },
  {
    "id": "puppeteer",
    "name": "Puppeteer",
    "summary": "Headless browser automation — navigate pages, take screenshots, and run in-page JavaScript.",
    "transport": "stdio",
    "command": "npx",
    "args": ["-y", "@modelcontextprotocol/server-puppeteer"],
    "requiresApproval": true,
    "source": "https://github.com/modelcontextprotocol/servers-archived/tree/main/src/puppeteer"
  },
  {
    "id": "brave-search",
