# NOTE: docs/** stays excluded — it's internal planning/review material (PRD, DevPlan, Codex
# logs, review handoffs). Only README/USAGE/CHANGELOG ship to users.

# NOTE: node_modules is intentionally NOT ignored — this extension is not
# bundled (build = tsc only), so it ships its production dependencies (uuid,
# @modelcontextprotocol/sdk). vsce automatically excludes devDependencies.

# ...but a dependency's own TypeScript sources and test files are never needed at
# runtime (we ship compiled JS), so trim them to keep the VSIX lean (e.g. zod ships
# src/**/*.test.ts). Safe: these are never require()'d by the extension.
node_modules/**/*.test.ts
node_modules/**/*.spec.ts
node_modules/zod/src/**
